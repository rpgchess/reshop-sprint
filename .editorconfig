# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = crlf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

# HTA files (HTML Application)
[*.hta]
indent_style = tab
indent_size = 4
charset = utf-8
end_of_line = crlf

# HTML files
[*.html]
indent_style = tab
indent_size = 4
charset = utf-8

# JavaScript files
[*.js]
indent_style = tab
indent_size = 4
charset = utf-8

# CSS files
[*.css]
indent_style = tab
indent_size = 4
charset = utf-8

# Markdown files
[*.md]
trim_trailing_whitespace = false
